{
    "name": "@embedthis/ejscript",
    "owner": "embedthis",
    "version": "2.1.1",
    "description": "Ejscript core API implementation for Bun runtime",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./globals": {
            "types": "./dist/globals.d.ts",
            "import": "./dist/globals.js"
        }
    },
    "files": [
        "dist",
        "src",
        "README.md",
        "LICENSE.md"
    ],
    "scripts": {
        "build": "bun build.ts",
        "test": "tm",
        "typecheck": "tsc --noEmit",
        "dev": "bun --watch src/index.ts",
        "prepublishOnly": "bun run typecheck && bun run build"
    },
    "keywords": [
        "ejscript",
        "es4",
        "bun",
        "typescript",
        "javascript",
        "runtime",
        "path",
        "file",
        "http",
        "socket",
        "websocket",
        "worker",
        "bytearray",
        "streams"
    ],
    "author": "Ejscript Project",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/embedthis/ejscript.git"
    },
    "bugs": "https://github.com/embedthis/ejscript/issues",
    "homepage": "https://www.embedthis.com/ejs/",
    "license": "GPL-2.0-only",
    "publishConfig": {
        "access": "public"
    },
    "devDependencies": {
        "@embedthis/testme": "^0.8.32",
        "@types/bun": "latest",
        "typescript": "^7.0.2"
    },
    "engines": {
        "bun": ">=1.0.0"
    },
    "pak": {
        "export": false,
        "files": [
            "dist/**",
            "README.md",
            "LICENSE.md"
        ]
    }
}
